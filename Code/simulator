"use client";

import React, { useEffect, useMemo, useRef, useState } from "react";
import { Camera, Lock, RotateCcw, Unlock, User } from "lucide-react";

type UserWorld = {
  x: number;
  z: number;
};

type TcpPose = {
  x: number;
  z: number;
};

type JointState = {
  shoulder: number;
  elbow: number;
  wrist: number;
};

type PIDState = {
  integral: number;
  prevError: number;
  derivFiltered: number;
};

type CameraFace = {
  x: number;
  y: number;
  r: number;
};

const LOOP_HZ = 30;
const DT = 1 / LOOP_HZ;

// Goal: keep camera this far from user
const TARGET_STANDOFF = 170;

// World bounds
const USER_X_MIN = 380;
const USER_X_MAX = 760;
const USER_Z_MIN = 120;
const USER_Z_MAX = 320;

const TCP_X_MIN = 180;
const TCP_X_MAX = 620;
const TCP_Z_MIN = 110;
const TCP_Z_MAX = 330;

const TCP_X0 = 320;
const TCP_Z0 = 220;

// Camera frame
const CAM_W = 320;
const CAM_H = 220;

// User pad
const PAD_W = 320;
const PAD_H = 240;

// Right-side arm view
const VIEW_W = 1000;
const VIEW_H = 560;
const BASE_X = 860;
const BASE_Y = 430;

// Arm link lengths
const L1 = 180;
const L2 = 150;

// Joint limits
const SHOULDER_MIN = 5;
const SHOULDER_MAX = 155;
const ELBOW_MIN = 12;
const ELBOW_MAX = 175;
const WRIST_MIN = -120;
const WRIST_MAX = 120;

function clamp(v: number, lo: number, hi: number) {
  return Math.max(lo, Math.min(hi, v));
}

function lerp(a: number, b: number, t: number) {
  return a + (b - a) * t;
}

function mapRange(
  v: number,
  inMin: number,
  inMax: number,
  outMin: number,
  outMax: number
) {
  if (Math.abs(inMax - inMin) < 1e-9) return outMin;
  const u = (v - inMin) / (inMax - inMin);
  return outMin + u * (outMax - outMin);
}

function rad(degValue: number) {
  return (degValue * Math.PI) / 180;
}

function deg(radValue: number) {
  return (radValue * 180) / Math.PI;
}

function applyDeadband(v: number, db: number) {
  return Math.abs(v) < db ? 0 : v;
}

function resetPid(): PIDState {
  return {
    integral: 0,
    prevError: 0,
    derivFiltered: 0,
  };
}

function pidUpdate(
  error: number,
  dt: number,
  state: PIDState,
  gains: {
    kp: number;
    ki: number;
    kd: number;
    outMin: number;
    outMax: number;
    iMin: number;
    iMax: number;
    dAlpha: number;
  }
) {
  state.integral = clamp(state.integral + error * dt, gains.iMin, gains.iMax);

  const derivRaw = dt > 0 ? (error - state.prevError) / dt : 0;
  state.derivFiltered = lerp(state.derivFiltered, derivRaw, gains.dAlpha);

  const out =
    gains.kp * error +
    gains.ki * state.integral +
    gains.kd * state.derivFiltered;

  state.prevError = error;
  return clamp(out, gains.outMin, gains.outMax);
}

// World TCP -> screen target in right-side arm panel
function tcpToScreen(tcp: TcpPose) {
  return {
    x: mapRange(tcp.x, TCP_X_MIN, TCP_X_MAX, 700, 330),
    y: mapRange(tcp.z, TCP_Z_MIN, TCP_Z_MAX, 430, 130),
  };
}

// Robust IK target from tcp
function solveIkFromTcp(tcp: TcpPose): JointState {
  const target = tcpToScreen(tcp);

  // target relative to base
  const lx = BASE_X - target.x; // leftward positive
  const ly = BASE_Y - target.y; // upward positive

  const dRaw = Math.sqrt(lx * lx + ly * ly);
  const minReach = Math.abs(L1 - L2) + 8;
  const maxReach = L1 + L2 - 8;
  const d = clamp(dRaw, minReach, maxReach);

  const cosElbow = clamp(
    (d * d - L1 * L1 - L2 * L2) / (2 * L1 * L2),
    -1,
    1
  );
  const elbowRad = Math.acos(cosElbow);

  const shoulderRad =
    Math.atan2(ly, lx) -
    Math.atan2(L2 * Math.sin(elbowRad), L1 + L2 * Math.cos(elbowRad));

  const shoulderDeg = clamp(deg(shoulderRad), SHOULDER_MIN, SHOULDER_MAX);
  const elbowDeg = clamp(deg(elbowRad), ELBOW_MIN, ELBOW_MAX);

  // keep phone roughly vertical / facing user
  const wristDeg = clamp(
    -(shoulderDeg + elbowDeg - 180) * 0.55,
    WRIST_MIN,
    WRIST_MAX
  );

  return {
    shoulder: shoulderDeg,
    elbow: elbowDeg,
    wrist: wristDeg,
  };
}

function forwardKinematics(j: JointState) {
  const s = rad(j.shoulder);
  const e = rad(j.elbow);

  const x1 = BASE_X - L1 * Math.cos(s);
  const y1 = BASE_Y - L1 * Math.sin(s);

  const x2 = x1 - L2 * Math.cos(s + e);
  const y2 = y1 - L2 * Math.sin(s + e);

  return { x1, y1, x2, y2 };
}

// Face location in camera frame depends ONLY on current tcp + user world location
function computeCameraFace(user: UserWorld, tcp: TcpPose): CameraFace {
  // centered when tcp.x + TARGET_STANDOFF == user.x
  // centered vertically when tcp.z == user.z
  const errX = user.x - (tcp.x + TARGET_STANDOFF);
  const errY = user.z - tcp.z;

  const cx = CAM_W / 2;
  const cy = CAM_H / 2;

  const faceX = clamp(cx + errX * 0.7, 28, CAM_W - 28);
  const faceY = clamp(cy - errY * 1.0, 28, CAM_H - 28);

  const actualDistance = clamp(user.x - tcp.x, 80, 320);
  const radius = clamp(mapRange(actualDistance, 80, 320, 34, 16), 16, 34);

  return {
    x: faceX,
    y: faceY,
    r: radius,
  };
}

export default function Page() {
  const [locked, setLocked] = useState(false);

  const [userWorld, setUserWorld] = useState<UserWorld>({
    x: 560,
    z: 220,
  });

  // world-space camera/phone position
  const [tcp, setTcp] = useState<TcpPose>({
    x: TCP_X0,
    z: TCP_Z0,
  });

  // actually drawn arm joints
  const [joints, setJoints] = useState<JointState>({
    shoulder: 42,
    elbow: 88,
    wrist: 0,
  });

  const pidRef = useRef({
    x: resetPid(),
    z: resetPid(),
  });

  const draggingRef = useRef(false);
  const padRef = useRef<HTMLDivElement | null>(null);

  // Main closed loop
  useEffect(() => {
    const interval = window.setInterval(() => {
      if (locked) return;

      // 1. compute world-space image-centering error
      const errX = userWorld.x - (tcp.x + TARGET_STANDOFF);
      const errZ = userWorld.z - tcp.z;

      const ex = applyDeadband(errX, 1.5);
      const ez = applyDeadband(errZ, 1.5);

      // 2. update tcp pose
      const vx = pidUpdate(ex, DT, pidRef.current.x, {
        kp: 2.2,
        ki: 0.02,
        kd: 0.5,
        outMin: -260,
        outMax: 260,
        iMin: -140,
        iMax: 140,
        dAlpha: 0.25,
      });

      const vz = pidUpdate(ez, DT, pidRef.current.z, {
        kp: 2.8,
        ki: 0.025,
        kd: 0.55,
        outMin: -260,
        outMax: 260,
        iMin: -140,
        iMax: 140,
        dAlpha: 0.25,
      });

      const nextTcp: TcpPose = {
        x: clamp(tcp.x + clamp(vx * DT, -10, 10), TCP_X_MIN, TCP_X_MAX),
        z: clamp(tcp.z + clamp(vz * DT, -10, 10), TCP_Z_MIN, TCP_Z_MAX),
      };

      // 3. solve target joints from NEW tcp
      const targetJoints = solveIkFromTcp(nextTcp);

      // 4. animate drawn arm toward target joints
      const nextJoints: JointState = {
        shoulder: lerp(joints.shoulder, targetJoints.shoulder, 0.22),
        elbow: lerp(joints.elbow, targetJoints.elbow, 0.22),
        wrist: lerp(joints.wrist, targetJoints.wrist, 0.22),
      };

      setTcp(nextTcp);
      setJoints(nextJoints);
    }, 1000 / LOOP_HZ);

    return () => window.clearInterval(interval);
  }, [locked, tcp, joints, userWorld]);

  const fk = useMemo(() => forwardKinematics(joints), [joints]);
  const cameraFace = useMemo(() => computeCameraFace(userWorld, tcp), [userWorld, tcp]);

  function resetAll() {
    setUserWorld({
      x: 560,
      z: 220,
    });

    setTcp({
      x: TCP_X0,
      z: TCP_Z0,
    });

    setJoints({
      shoulder: 42,
      elbow: 88,
      wrist: 0,
    });

    pidRef.current.x = resetPid();
    pidRef.current.z = resetPid();
  }

  function updateUserFromPointer(clientX: number, clientY: number) {
    if (!padRef.current) return;

    const rect = padRef.current.getBoundingClientRect();
    const px = clamp(clientX - rect.left, 0, rect.width);
    const py = clamp(clientY - rect.top, 0, rect.height);

    const worldX = mapRange(px, 0, rect.width, USER_X_MIN, USER_X_MAX);
    const worldZ = mapRange(py, rect.height, 0, USER_Z_MIN, USER_Z_MAX);

    setUserWorld({
      x: clamp(worldX, USER_X_MIN, USER_X_MAX),
      z: clamp(worldZ, USER_Z_MIN, USER_Z_MAX),
    });
  }

  const padUserX = mapRange(userWorld.x, USER_X_MIN, USER_X_MAX, 24, PAD_W - 24);
  const padUserY = mapRange(userWorld.z, USER_Z_MIN, USER_Z_MAX, PAD_H - 24, 24);

  const tcpScreen = tcpToScreen(tcp);
  const userViewX = mapRange(userWorld.x, USER_X_MIN, USER_X_MAX, 700, 160);
  const userViewY = mapRange(userWorld.z, USER_Z_MIN, USER_Z_MAX, 440, 130);

  const errXDisplay = userWorld.x - (tcp.x + TARGET_STANDOFF);
  const errZDisplay = userWorld.z - tcp.z;

  return (
    <div className="min-h-screen bg-slate-950 text-slate-100">
      <div className="mx-auto max-w-7xl px-6 py-8">
        <div className="mb-6 flex items-center justify-between">
          <div>
            <h1 className="text-3xl font-bold tracking-tight">HeadsUp Arm Simulator</h1>
            <p className="mt-2 text-slate-400">
              Move the user on the left. The arm on the right should visibly move,
              and the face in the camera frame should shift because of that arm motion.
            </p>
          </div>

          <div className="flex items-center gap-3">
            <button
              onClick={() => setLocked((v) => !v)}
              className={`rounded-xl border px-4 py-2 text-sm font-semibold transition ${
                locked
                  ? "border-red-500/50 bg-red-500/10 text-red-300"
                  : "border-emerald-500/50 bg-emerald-500/10 text-emerald-300"
              }`}
            >
              <span className="inline-flex items-center gap-2">
                {locked ? <Lock size={16} /> : <Unlock size={16} />}
                {locked ? "Locked" : "Active"}
              </span>
            </button>

            <button
              onClick={resetAll}
              className="rounded-xl border border-slate-700 bg-slate-900 px-4 py-2 text-sm font-semibold text-slate-200 transition hover:border-blue-500 hover:text-blue-300"
            >
              <span className="inline-flex items-center gap-2">
                <RotateCcw size={16} />
                Reset
              </span>
            </button>
          </div>
        </div>

        <div className="grid grid-cols-1 gap-6 lg:grid-cols-[360px_1fr]">
          {/* LEFT COLUMN */}
          <div className="space-y-6">
            <div className="rounded-3xl border border-slate-800 bg-slate-900/70 p-4 shadow-2xl shadow-black/20">
              <div className="mb-3 flex items-center gap-2">
                <Camera size={18} className="text-blue-400" />
                <h2 className="text-lg font-semibold">Camera Frame</h2>
              </div>

              <svg
                width="100%"
                viewBox={`0 0 ${CAM_W} ${CAM_H}`}
                className="rounded-2xl border border-slate-800 bg-slate-950"
              >
                <rect x="0" y="0" width={CAM_W} height={CAM_H} fill="#020617" />
                <line
                  x1={CAM_W / 2}
                  y1="0"
                  x2={CAM_W / 2}
                  y2={CAM_H}
                  stroke="#1e293b"
                  strokeDasharray="5 5"
                />
                <line
                  x1="0"
                  y1={CAM_H / 2}
                  x2={CAM_W}
                  y2={CAM_H / 2}
                  stroke="#1e293b"
                  strokeDasharray="5 5"
                />

                <circle
                  cx={cameraFace.x}
                  cy={cameraFace.y}
                  r={cameraFace.r}
                  fill="rgba(59,130,246,0.10)"
                  stroke="#3b82f6"
                  strokeDasharray="5 5"
                  strokeWidth="2"
                />
                <circle cx={cameraFace.x} cy={cameraFace.y} r="4" fill="#60a5fa" />

                <text x="12" y="18" fill="#94a3b8" fontSize="12" fontWeight="bold">
                  Face position caused by current arm camera position
                </text>
              </svg>

              <p className="mt-3 text-sm text-slate-400">
                The face does not move by itself. It moves only because the current arm
                camera position changes.
              </p>
            </div>

            <div className="rounded-3xl border border-slate-800 bg-slate-900/70 p-4 shadow-2xl shadow-black/20">
              <div className="mb-3 flex items-center gap-2">
                <User size={18} className="text-blue-400" />
                <h2 className="text-lg font-semibold">User Position Control</h2>
              </div>

              <div
                ref={padRef}
                className="relative rounded-2xl border border-slate-800 bg-slate-950"
                style={{ width: "100%", height: 260 }}
                onMouseDown={(e) => {
                  draggingRef.current = true;
                  updateUserFromPointer(e.clientX, e.clientY);
                }}
                onMouseMove={(e) => {
                  if (!draggingRef.current) return;
                  updateUserFromPointer(e.clientX, e.clientY);
                }}
                onMouseUp={() => {
                  draggingRef.current = false;
                }}
                onMouseLeave={() => {
                  draggingRef.current = false;
                }}
              >
                <svg width="100%" height="100%" viewBox={`0 0 ${PAD_W} ${PAD_H}`}>
                  <rect x="0" y="0" width={PAD_W} height={PAD_H} fill="#020617" />

                  {Array.from({ length: 7 }).map((_, i) => (
                    <line
                      key={`pv-${i}`}
                      x1={(i * PAD_W) / 6}
                      y1="0"
                      x2={(i * PAD_W) / 6}
                      y2={PAD_H}
                      stroke="#132032"
                    />
                  ))}
                  {Array.from({ length: 6 }).map((_, i) => (
                    <line
                      key={`ph-${i}`}
                      x1="0"
                      y1={(i * PAD_H) / 5}
                      x2={PAD_W}
                      y2={(i * PAD_H) / 5}
                      stroke="#132032"
                    />
                  ))}

                  <text x="12" y="18" fill="#94a3b8" fontSize="12" fontWeight="bold">
                    Drag the user icon
                  </text>

                  <g transform={`translate(${padUserX}, ${padUserY})`}>
                    <circle r="22" fill="rgba(59,130,246,0.10)" stroke="#3b82f6" />
                    <circle r="8" cy="-12" fill="#60a5fa" />
                    <path
                      d="M -10 12 Q 0 0 10 12"
                      fill="none"
                      stroke="#60a5fa"
                      strokeWidth="4"
                      strokeLinecap="round"
                    />
                    <path
                      d="M -12 28 L 12 28"
                      fill="none"
                      stroke="#60a5fa"
                      strokeWidth="4"
                      strokeLinecap="round"
                    />
                  </g>

                  <text x="12" y={PAD_H - 10} fill="#64748b" fontSize="11">
                    Horizontal = distance, Vertical = height
                  </text>
                </svg>
              </div>
            </div>
          </div>

          {/* RIGHT COLUMN */}
          <div className="rounded-3xl border border-slate-800 bg-slate-900/70 p-4 shadow-2xl shadow-black/20">
            <div className="mb-3 flex items-center justify-between">
              <h2 className="text-lg font-semibold">Robotic Arm Side View</h2>
              <div className="text-sm text-slate-400">Arm motion should be visible</div>
            </div>

            <svg
              width="100%"
              viewBox={`0 0 ${VIEW_W} ${VIEW_H}`}
              className="rounded-2xl border border-slate-800 bg-slate-950"
            >
              <defs>
                <linearGradient id="armGrad" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stopColor="#334155" />
                  <stop offset="100%" stopColor="#475569" />
                </linearGradient>
              </defs>

              {Array.from({ length: 17 }).map((_, i) => (
                <line
                  key={`gv-${i}`}
                  x1={i * 60}
                  y1="0"
                  x2={i * 60}
                  y2={VIEW_H}
                  stroke="#132032"
                />
              ))}
              {Array.from({ length: 10 }).map((_, i) => (
                <line
                  key={`gh-${i}`}
                  x1="0"
                  y1={i * 56}
                  x2={VIEW_W}
                  y2={i * 56}
                  stroke="#132032"
                />
              ))}

              <line x1="120" y1="442" x2="940" y2="442" stroke="#223247" strokeWidth="3" />

              {/* user in world side-view */}
              <g transform={`translate(${userViewX}, ${userViewY})`}>
                <circle cx="0" cy="-44" r="20" fill="rgba(96,165,250,0.35)" />
                <rect
                  x="-16"
                  y="-22"
                  width="32"
                  height="70"
                  rx="14"
                  fill="rgba(96,165,250,0.22)"
                />
                <text
                  x="-18"
                  y="-74"
                  fill="#93c5fd"
                  fontSize="14"
                  fontWeight="bold"
                >
                  USER
                </text>
              </g>

              {/* base */}
              <rect x={BASE_X - 24} y={BASE_Y + 6} width="48" height="22" rx="5" fill="#111827" />
              <rect x={BASE_X - 16} y={BASE_Y - 48} width="32" height="54" rx="8" fill="#1e293b" />

              {/* upper arm */}
              <line
                x1={BASE_X}
                y1={BASE_Y}
                x2={fk.x1}
                y2={fk.y1}
                stroke="url(#armGrad)"
                strokeWidth="20"
                strokeLinecap="round"
              />
              <circle cx={BASE_X} cy={BASE_Y} r="14" fill="#3b82f6" />
              <circle cx={fk.x1} cy={fk.y1} r="12" fill="#3b82f6" />

              {/* forearm */}
              <line
                x1={fk.x1}
                y1={fk.y1}
                x2={fk.x2}
                y2={fk.y2}
                stroke="url(#armGrad)"
                strokeWidth="18"
                strokeLinecap="round"
              />
              <circle cx={fk.x2} cy={fk.y2} r="10" fill="#3b82f6" />

              {/* phone/camera */}
              <g transform={`translate(${fk.x2}, ${fk.y2}) rotate(${joints.wrist})`}>
                <rect x="-18" y="-8" width="36" height="10" rx="3" fill="#1e293b" />
                <rect
                  x="-18"
                  y="-54"
                  width="36"
                  height="46"
                  rx="6"
                  fill="#020617"
                  stroke="#334155"
                  strokeWidth="2"
                />
                <circle cx="0" cy="-31" r="5" fill="#60a5fa" />
              </g>

              {/* tcp target marker */}
              <circle
                cx={tcpScreen.x}
                cy={tcpScreen.y}
                r="14"
                fill="none"
                stroke="#60a5fa"
                strokeDasharray="5 5"
                strokeWidth="2"
              />

              <text x="28" y="32" fill="#94a3b8" fontSize="14" fontWeight="bold">
                The arm drawing follows the current tcp pose every loop
              </text>
            </svg>

            <div className="mt-4 grid grid-cols-2 gap-4 xl:grid-cols-4">
              <div className="rounded-2xl border border-slate-800 bg-slate-950 p-4">
                <div className="text-sm text-slate-500">World Error X</div>
                <div className="mt-1 font-mono text-blue-300">
                  {errXDisplay.toFixed(1)}
                </div>
              </div>

              <div className="rounded-2xl border border-slate-800 bg-slate-950 p-4">
                <div className="text-sm text-slate-500">World Error Z</div>
                <div className="mt-1 font-mono text-blue-300">
                  {errZDisplay.toFixed(1)}
                </div>
              </div>

              <div className="rounded-2xl border border-slate-800 bg-slate-950 p-4">
                <div className="text-sm text-slate-500">TCP Position</div>
                <div className="mt-1 font-mono text-blue-300">
                  X {tcp.x.toFixed(1)} / Z {tcp.z.toFixed(1)}
                </div>
              </div>

              <div className="rounded-2xl border border-slate-800 bg-slate-950 p-4">
                <div className="text-sm text-slate-500">Joint Angles</div>
                <div className="mt-1 font-mono text-blue-300">
                  S {joints.shoulder.toFixed(1)}° / E {joints.elbow.toFixed(1)}° / W{" "}
                  {joints.wrist.toFixed(1)}°
                </div>
              </div>
            </div>

            <div className="mt-4 rounded-2xl border border-slate-800 bg-slate-950 p-4 text-sm text-slate-400">
              Expected behavior: after you drag the user, the arm should visibly move on
              the right. As that arm motion changes the tcp position, the face in the
              camera frame should gradually move back toward center.
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
